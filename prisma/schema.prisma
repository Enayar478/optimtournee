generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String   @id @default(cuid())
  clerkId             String   @unique
  email               String   @unique
  name                String?
  createdAt           DateTime @default(now())
  companyAddress      String?
  companyName         String?
  companyPhone        String?
  companySiret        String?
  onboardingCompleted Boolean  @default(false)
  clients             Client[]
  teams               Team[]
}

model Client {
  id           String             @id @default(cuid())
  userId       String
  name         String
  address      String
  lat          Float
  lng          Float
  contactPhone String?
  contactEmail String?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id])
  contract     RecurringContract?
}

model Team {
  id                  String             @id @default(cuid())
  userId              String
  name                String
  color               String             @default("#2D5A3D")
  defaultStartAddress String?
  defaultStartLat     Float?
  defaultStartLng     Float?
  workScheduleStart   String             @default("08:00")
  workScheduleEnd     String             @default("17:00")
  lunchBreakMinutes   Int                @default(60)
  workingDays         Int[]
  unavailableDates    DateTime[]
  skills              InterventionType[]
  assignedEquipment   EquipmentType[]
  user                User               @relation(fields: [userId], references: [id])
  members             TeamMember[]
}

model TeamMember {
  id           String   @id @default(cuid())
  teamId       String
  firstName    String
  lastName     String
  phone        String?
  licenseTypes String[]
  team         Team     @relation(fields: [teamId], references: [id])
}

model Equipment {
  id               String        @id @default(cuid())
  type             EquipmentType
  name             String
  requiresTrailer  Boolean       @default(false)
  maintenanceDates DateTime[]
}

model RecurringContract {
  id                String           @id @default(cuid())
  clientId          String           @unique
  recurrence        RecurrenceType
  dayOfWeek         Int
  interventionType  InterventionType
  durationMinutes   Int
  requiredEquipment EquipmentType[]
  priority          Int              @default(1)
  startDate         DateTime
  endDate           DateTime?
  notes             String?
  maxWindSpeed      Float            @default(50)
  noRainForecast    Boolean          @default(false)
  minTemperature    Float            @default(-5)
  maxTemperature    Float            @default(40)
  client            Client           @relation(fields: [clientId], references: [id])
}

model OneOffRequest {
  id                 String           @id @default(cuid())
  clientId           String
  requestDate        DateTime         @default(now())
  preferredDateStart DateTime?
  preferredDateEnd   DateTime?
  interventionType   InterventionType
  description        String
  durationEstimate   Int
  requiredEquipment  EquipmentType[]
  priority           Int              @default(1)
  status             OneOffStatus     @default(pending)
  maxWindSpeed       Float            @default(50)
  noRainForecast     Boolean          @default(false)
  minTemperature     Float            @default(-5)
  maxTemperature     Float            @default(40)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model PlannedIntervention {
  id                         String             @id @default(cuid())
  sourceType                 SourceType
  sourceContractId           String?
  sourceRequestId            String?
  clientId                   String
  interventionType           InterventionType
  scheduledDate              DateTime
  estimatedStartTime         String
  estimatedDurationMinutes   Int
  assignedTeamId             String
  assignedEquipment          EquipmentType[]
  status                     InterventionStatus @default(planned)
  routeOrder                 Int                @default(0)
  estimatedTravelTimeMinutes Int                @default(0)
  estimatedTravelDistanceKm  Float              @default(0)
  weatherDate                DateTime?
  weatherTemperature         Float?
  weatherWindSpeed           Float?
  weatherRainProbability     Float?
  weatherRainMm              Float?
  weatherCondition           WeatherCondition?
  weatherIsSuitable          Boolean?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
}

model Schedule {
  id                       String   @id @default(cuid())
  name                     String
  startDate                DateTime
  endDate                  DateTime
  generatedAt              DateTime @default(now())
  version                  Int      @default(1)
  totalInterventions       Int      @default(0)
  totalDistanceKm          Float    @default(0)
  totalDrivingTimeHours    Float    @default(0)
  clientsServed            Int      @default(0)
  teamsUtilized            Int      @default(0)
  estimatedTimeSavedHours  Float?
  estimatedFuelSavedLiters Float?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

enum RecurrenceType {
  weekly
  biweekly
  monthly
  bimonthly
  quarterly
}

enum InterventionType {
  mowing
  hedge_trimming
  pruning
  weeding
  planting
  maintenance
  emergency
}

enum InterventionStatus {
  planned
  in_progress
  completed
  cancelled
  postponed
}

enum EquipmentType {
  lawn_tractor
  push_mower
  hedge_trimmer
  chainsaw
  blower
  trailer
  utility_vehicle
}

enum OneOffStatus {
  pending
  scheduled
  completed
  cancelled
}

enum SourceType {
  recurring
  oneoff
}

enum WeatherCondition {
  clear
  cloudy
  rain
  storm
  snow
}
